# ---- Source Postgres (read-only) ----
DATABASE_URL=

# ---- OpenRouter (chat LLM) ----
OPENROUTER_API_KEY=sk-or-v1-...your-key-here...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=anthropic/claude-haiku-4.5
OPENROUTER_TIMEOUT=30
OPENROUTER_MAX_RETRIES=2

# ---- Embedding model (local, sentence-transformers) ----
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_BATCH_SIZE=64
EMBEDDING_DEVICE=cpu

# ---- Vector store (Chroma, local persistent) ----
CHROMA_DIR=./chroma_data
CHROMA_COLLECTION=roles_v1

# ---- Sparse retriever (BM25, on-disk pickle) ----
BM25_INDEX_PATH=./bm25_index.pkl

# ---- Session store (SQLite) ----
SESSIONS_DB=./sessions.db

# ---- Retrieval & ranking tuning ----
RETRIEVAL_TOP_K_DENSE=100
RETRIEVAL_TOP_K_SPARSE=100
RRF_K=60
RERANK_TOP_K=50
FINAL_TOP_K=5
WHY_NOT_K=5               # candidates at ranks 6..(5+WHY_NOT_K) get "why-not" explanations
MMR_LAMBDA=0.7
PRIOR_SHORTLIST_BOOST=0.05

# ---- Signal weights (sum ~= 1.0; tuned against golden queries) ----
WEIGHT_INDUSTRY=0.25
WEIGHT_FUNCTION=0.20
WEIGHT_SENIORITY=0.20
WEIGHT_SKILL_CATEGORY=0.10
WEIGHT_RECENCY=0.10
WEIGHT_DENSE=0.10
WEIGHT_BM25=0.05

# ---- MaxP aggregation ----
MAXP_MULTI_ROLE_BONUS=0.05   # added per additional matching role, capped
MAXP_MULTI_ROLE_CAP=0.15

# ---- Logging ----
LOG_LEVEL=INFO
LOG_FORMAT=json              # json | text

# ---- Server ----
API_HOST=0.0.0.0
API_PORT=8000
