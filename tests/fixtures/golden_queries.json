{
  "comment": "Hand-labeled eval set. Relevance is PREDICATE-based because the source data is synthetic and exact candidate_ids are unknown. Each query defines a `relevance_predicate` with `must` (hard-filter compliance) and `should` (soft-signal match). Grading: 2 if all must + all should; 1 if all must only; 0 if any must is violated. Country codes are ISO-3166 alpha-2. Industry values are the canonical names present in companies.industry (see scripts/inspect_data.py). See DESIGN.md sec. 10 for the evaluation methodology.",
  "schema_version": "1.0",
  "queries": [
    {
      "id": "q01",
      "query": "Find me regulatory affairs experts with experience in the pharmaceutical industry in the Middle East.",
      "expected_constraints": {
        "geographies": ["SA", "AE", "QA", "EG", "OM", "PS", "JO", "LB", "KW", "BH", "SY", "IQ", "YE", "IL", "TR"],
        "industries": ["Pharmaceuticals"],
        "function": "regulatory affairs",
        "seniority_band": null,
        "require_current": null,
        "min_yoe": null
      },
      "relevance_predicate": {
        "must": {
          "country_in": ["SA", "AE", "QA", "EG", "OM", "PS", "JO", "LB", "KW", "BH", "SY", "IQ", "YE", "IL", "TR"]
        },
        "should": {
          "title_contains_any": ["regulatory", "compliance", "affairs", "quality"],
          "industry_in": ["Pharmaceuticals", "Hospitals and Health Care"]
        }
      },
      "grading": {
        "grade_2": "all must + all should (true positive)",
        "grade_1": "all must only (partial match)",
        "grade_0": "any must violation"
      },
      "notes": "Anchor query (assessment example). Tests region-to-country expansion, industry alias (pharma -> Pharmaceuticals), and function extraction. Primary hard-filter test."
    },
    {
